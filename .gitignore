# Build output
build/
*.o
*.elf
*.nds
*.bin

# ROM files — NEVER commit these
rom/baserom.nds
rom/*.nds

# Extracted ROM data (generated from user's ROM)
extracted/

# Assembly stubs generated from ROM binary (contains copyrighted machine code)
# These are regenerated by split_arm9.py from the user's own ROM
arm9/asm/func/
arm9/asm/gaps/

# Ghidra decompiled output (derived from ROM)
config/decompiled/

# Ghidra projects
*.gpr
*.rep/
ghidra_projects/

